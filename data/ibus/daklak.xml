<?xml version="1.0" encoding="utf-8"?>
<!--
  IBus component descriptor for daklak Vietnamese IME.

  After install, run to make the engine appear in ibus-setup / GNOME Settings:
    ibus write-cache
    ibus restart          # or log out and back in

  Then: ibus-setup → Input Method → Add → Vietnamese → Vietnamese (Daklak)
  Or CLI: ibus engine daklak

  @bindir@ and @version@ are substituted by meson at install time.
-->
<component>
    <name>org.freedesktop.IBus.Daklak</name>
    <description>Daklak Vietnamese input method</description>
    <exec>@bindir@/daklak --ibus</exec>
    <version>@version@</version>
    <author>daklak contributors</author>
    <license>GPL-3.0-or-later</license>
    <homepage>https://github.com/mozartilize/daklak-rs</homepage>
    <textdomain>daklak</textdomain>
    <engines>
        <engine>
            <name>daklak</name>
            <language>vi</language>
            <license>GPL-3.0-or-later</license>
            <author>daklak contributors</author>
            <layout>us</layout>
            <longname>Daklak</longname>
            <description>Telex/VNI Vietnamese — daklak IME</description>
            <icon>ibus-keyboard</icon>
            <rank>50</rank>
            <symbol>dk</symbol>
        </engine>
    </engines>
</component>
