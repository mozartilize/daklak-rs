# udev rule for daklak: grant access to /dev/uinput without requiring root.
#
# Install:
#   sudo cp res/99-daklak.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger --name-match=uinput
#   sudo usermod -aG input $USER   # then log out + back in
#
# Verify: ls -l /dev/uinput  →  crw-rw---- root input
#
# SECURITY: /dev/uinput permits synthetic keyboard injection. The input group
# is high-trust on Linux desktops; only add users/processes you trust with input
# observation/injection. TAG+="uaccess" grants the active local session user via
# systemd-logind on systems that support it.
KERNEL=="uinput", GROUP="input", MODE="0660", TAG+="uaccess"
