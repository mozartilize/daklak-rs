# Daklak config example.
# Copy to $XDG_CONFIG_HOME/daklak/config.toml to use.

# Input method: telex | vni | viqr
# default: "telex"
method = "telex"

# Enable Wayland input-method path. Set false to use evdev-only mode
# together with enable_evdev_grab = true.
# default: true
enable_wayland = true

# Logging.
# default: "error"
log_level = "error"
# default: "/dev/stdout"
log_path = "/dev/stdout"
# Per-target overrides; trace is accepted as an alias for debug.
log_modules = ["daklak=debug", "viet_ime_wayland_adapter=info"]

# Force these app_id values to Tier 4 VkOnly routing (case-insensitive).
# default: []
force_vk_only_apps = []

# Treat all focused XWayland windows as VkOnly.
# default: true
auto_vk_only_for_xwayland = true

# Open and grab /dev/input/event* keyboards at startup.
# When true, evdev runs alongside the native backend (ibus/wayland).
# The tray "Enable evdev" toggle persists changes here.
# default: false
enable_evdev_grab = false

# Evdev setup hooks to run when evdev grab is activated.
# SECURITY: hooks are executable programs. A file such as
# $XDG_CONFIG_HOME/daklak/hooks/sway-set runs as your user with Daklak's
# environment. Treat that directory as sensitive as ~/.bashrc or
# ~/.config/autostart.
# Packaged installs ship sway, kde, gnome, and x11 hooks; user scripts with
# matching <name>-set and <name>-unset filenames override packaged hooks.
# The tray "Evdev hooks" submenu toggles entries here.
# default: []
evdev_grab_hooks = []

# Telex-only: allow []{} shortcuts for o-horn/u-horn.
# default: false
bracket_shortcuts = false

# Modern-style tone placement on oa/oe/uy diphthongs.
# true (default) → oà, false → òa (legacy).
# default: true
modern_style = true
